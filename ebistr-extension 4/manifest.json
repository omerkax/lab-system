{
  "manifest_version": 3,
  "name": "Alibey EBİSTR Token",
  "version": "1.0",
  "description": "EBİSTR token'ını otomatik yakalar ve proxy'ye kaydeder",
  "permissions": [
    "webRequest",
    "storage",
    "notifications",
    "downloads",
    "alarms",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.ebistr.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png"
  }
}